# Backend environment variables
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# PostgreSQL — used by Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_gen?schema=public

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars_long_xxxxx
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string_32_chars_min_yyyy
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12
COOKIE_SECURE=false
# COOKIE_DOMAIN=.example.com
