{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "express"],
    "baseUrl": ".",
    // `baseUrl` is deprecated and TypeScript 7 will remove it. We still use it
    // for the monorepo `paths` mapping, so silence the warning. The only
    // accepted value in TS 5.x is "5.0" — bumping this if/when we move to TS 6.
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["src/*"],
      "@ai-gen/shared": ["../../packages/shared/src/index.ts"],
      "@ai-gen/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../../packages/shared" }]
}
